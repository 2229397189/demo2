# MySQL
DB_USERNAME=root
DB_PASSWORD=root

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Milvus
MILVUS_ENABLED=false
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE=default

# Elasticsearch
ELASTICSEARCH_URIS=localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Neo4j
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=5
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=5

# OpenAI Compatible API
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=qwen3.7-max-2026-05-17
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=120
OPENAI_CONNECT_TIMEOUT=30

# Docker / Sandbox
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_PYTHON_IMAGE=python:3.11-slim
SANDBOX_NODE_IMAGE=node:20-slim
SANDBOX_JAVA_IMAGE=eclipse-temurin:17-jdk
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY=512m
SANDBOX_CPU=1.0
